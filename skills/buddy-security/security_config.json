{
  "owner_telegram_id": "CHANGE_ME",
  "pin_hash": "CHANGE_ME_USE_BCRYPT",
  "whitelist_paths": [
    "D:/BuddyWorkspace",
    "D:/Projects",
    "D:/Documents"
  ],
  "blacklist_commands": [
    "rm -rf /",
    "rm -rf ~",
    "rm -rf .",
    "rm -rf /*",
    "format",
    "shutdown",
    "del /s /q",
    "net user",
    "net localgroup",
    "reg delete",
    "reg add",
    "regedit",
    "powershell -enc",
    "powershell -encodedcommand",
    "cmd /c rd /s /q",
    "mkfs",
    "dd if=",
    "> /dev/sda",
    "wget | sh",
    "wget | bash",
    "curl | sh",
    "curl | bash",
    ":(){ :|:& };:",
    "chmod 777",
    "chown root"
  ],
  "sensitive_file_patterns": [
    "*.env",
    "*.env.*",
    "*.key",
    "*.pem",
    "*.cert",
    "*.p12",
    "*.pfx",
    "*password*",
    "*secret*",
    "*credential*",
    "*token*",
    "id_rsa",
    "id_ed25519",
    "*.keystore",
    ".git-credentials",
    ".npmrc",
    ".pypirc"
  ],
  "pin_timeout_seconds": 60,
  "max_pin_attempts": 3,
  "lockout_minutes": 15,
  "command_timeout_seconds": 300,
  "max_file_size_mb": 100,
  "audit_log_path": "data/audit.jsonl"
}
